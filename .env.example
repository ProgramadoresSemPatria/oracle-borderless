# =========================================================================
# Oracle Borderless — variáveis de ambiente
# Copie para .env e ajuste. NÃO comite o .env (está no .gitignore).
# Todas são lidas por src/support/core/settings.py (pydantic-settings).
# =========================================================================

# --- Ambiente ---
ENVIRONMENT=development        # development | staging | production
DEBUG=true
ENABLE_SCHEDULER=true

# --- Aplicação ---
APP_NAME="Oracle Borderless"
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Banco de dados (PostgreSQL — dual engine async asyncpg + sync psycopg) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=oracle
DB_PASSWORD=oracle
DB_NAME=oracle_borderless
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# --- Base de conhecimento: Notion via MCP (só documentos aprovados) ---
NOTION_MCP_URL=
NOTION_MCP_TOKEN=

# --- LLM do oráculo ---
# O oráculo pode usar Claude (Anthropic) OU GPT (OpenAI). Selecione o provedor:
LLM_PROVIDER=anthropic         # anthropic | openai

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI (GPT)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
